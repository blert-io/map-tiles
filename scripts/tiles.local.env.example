# Copy to scripts/tiles.local.env (gitignored) and fill in your values.
# These are read by scripts/tiles.py. Environment variables of the same name
# take precedence, so you can just export them instead.

# Destination bucket (required). The bucket must already exist.
TILES_BUCKET=my-osrs-tiles

# Cache-Control applied to every uploaded tile (optional).
# TILES_CACHE_CONTROL=public, max-age=86400

# DigitalOcean Spaces CDN endpoint id (optional). When set and `doctl` is
# installed, changed tiles are purged from the CDN after each sync.
# Find it with `doctl compute cdn list`.
# TILES_CDN_ENDPOINT_ID=00000000-0000-0000-0000-000000000000

# Public domain from which the tiles are served (optional).
# TILES_CDN_DOMAIN=tiles.example.com

# Force the `s3cmd` backend even if `s5cmd` is installed (optional).
# TILES_FORCE_S3CMD=1
